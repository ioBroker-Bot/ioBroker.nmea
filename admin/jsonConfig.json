{
    "type": "tabs",
    "i18n": true,
    "items": {
        "general": {
            "type": "panel",
            "label": "General",
            "items": {
                "type": {
                    "type": "select",
                    "label": "Hardware type",
                    "noTranslation": true,
                    "options": [
                        {
                            "label": "NGT-1",
                            "value": "ngt1"
                        },
                        {
                            "label": "PiCAN-M",
                            "value": "picanm"
                        },
                        {
                            "label": "Yacht Devices",
                            "value": "ydwg"
                        }
                    ],
                    "sm": 12,
                    "md": 6,
                    "lg": 4
                },
                "serialPort": {
                    "label": "Serial port",
                    "newLine": true,
                    "type": "selectSendTo",
                    "command": "list",
                    "manual": true,
                    "noTranslation": true,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "hidden": "data.type !== 'ngt1'"
                },
                "canPort": {
                    "label": "CAN port",
                    "newLine": true,
                    "type": "selectSendTo",
                    "command": "listCan",
                    "manual": true,
                    "noTranslation": true,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "hidden": "data.type !== 'picanm'"
                },
                "ydwgProtocol": {
                    "label": "Yacht Devices protocol",
                    "type": "select",
                    "options": [
                        {
                            "value": "tcp",
                            "label": "TCP"
                        },
                        {
                            "value": "udp",
                            "label": "UDP"
                        }
                    ],
                    "sm": 12,
                    "md": 2,
                    "lg": 1,
                    "default": "tcp",
                    "hidden": "data.type !== 'ydwg'"
                },
                "ydwgIp": {
                    "label": "IP",
                    "newLine": true,
                    "type": "text",
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "hidden": "data.type !== 'ydwg' || data.ydwgProtocol !== 'tcp'"
                },
                "ydwgPort": {
                    "label": "Port",
                    "type": "number",
                    "min": 1,
                    "max": 65535,
                    "sm": 12,
                    "md": 2,
                    "lg": 1,
                    "hidden": "data.type !== 'ydwg'",
                    "default": 1457
                },
                "updateAtLeastEveryMs": {
                    "newLine": true,
                    "label": "Update states at least every",
                    "help": "ms",
                    "type": "select",
                    "options": [
                        {
                            "label": "always update (not recommended)",
                            "value": 0
                        },
                        {
                            "label": "0,5 seconds",
                            "value": 500
                        },
                        {
                            "label": "1 second",
                            "value": 1000
                        },
                        {
                            "label": "2 seconds",
                            "value": 2000
                        },
                        {
                            "label": "5 seconds",
                            "value": 5000
                        },
                        {
                            "label": "10 seconds",
                            "value": 10000
                        },
                        {
                            "label": "15 seconds",
                            "value": 15000
                        },
                        {
                            "label": "30 seconds",
                            "value": 30000
                        },
                        {
                            "label": "1 minute",
                            "value": 60000
                        },
                        {
                            "label": "2 minutes",
                            "value": 120000
                        },
                        {
                            "label": "5 minutes",
                            "value": 120000
                        },
                        {
                            "label": "10 minutes",
                            "value": 600000
                        },
                        {
                            "label": "15 minutes",
                            "value": 900000
                        },
                        {
                            "label": "30 minutes",
                            "value": 1800000
                        },
                        {
                            "label": "1 hour",
                            "value": 3600000
                        },
                        {
                            "label": "2 hours",
                            "value": 7200000
                        },
                        {
                            "label": "5 hours",
                            "value": 18000000
                        },
                        {
                            "label": "10 hours",
                            "value": 36000000
                        },
                        {
                            "label": "24 hours",
                            "value": 86400000
                        }
                    ],
                    "sm": 12,
                    "md": 6,
                    "lg": 4
                },
                "approximateMs": {
                    "label": "Approximation time",
                    "help": "ms. Only for average and max values",
                    "type": "number",
                    "default": 10000,
                    "sm": 12,
                    "md": 6,
                    "lg": 4
                },
                "applyGpsTimeZoneToSystem": {
                    "label": "Use GPS time zone for system",
                    "type": "checkbox",
                    "sm": 12,
                    "md": 6,
                    "lg": 4
                },
                "deleteAisAfter": {
                    "label": "Delete AIS data if older than",
                    "help": "seconds",
                    "type": "number",
                    "min": 60,
                    "max": 604800,
                    "sm": 12,
                    "md": 6,
                    "lg": 4
                },
                "pressureAlertDiff": {
                    "newLine": true,
                    "label": "If pressure changes more than",
                    "help": "mbar, set alert flag",
                    "type": "number",
                    "min": 1,
                    "max": 50,
                    "sm": 12,
                    "md": 6,
                    "lg": 4
                },
                "pressureAlertMinutes": {
                    "newLine": true,
                    "label": "In period of time",
                    "help": "minutes",
                    "type": "number",
                    "min": 1,
                    "max": 1440,
                    "sm": 12,
                    "md": 6,
                    "lg": 4
                }
            }
        },
        "signalK": {
            "type": "panel",
            "label": "SignalK",
            "items": {
                "signalKEnabled": {
                    "label": "Enable SignalK server",
                    "type": "checkbox",
                    "default": false,
                    "sm": 12
                },
                "signalKPort": {
                    "label": "HTTP/WebSocket port",
                    "help": "Default SignalK port is 3000",
                    "type": "number",
                    "min": 1,
                    "max": 65535,
                    "default": 3000,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "disabled": "!data.signalKEnabled"
                },
                "signalKBidirectional": {
                    "label": "Allow SignalK clients to write to the bus",
                    "help": "Accept PUT/update deltas and inject them as PGNs (autopilot commands, simulated environment)",
                    "type": "checkbox",
                    "default": true,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "disabled": "!data.signalKEnabled"
                }
            }
        },
        "simulate": {
            "type": "panel",
            "label": "Simulate",
            "items": {
                "simulationEnabled": {
                    "label": "Enabled",
                    "type": "checkbox",
                    "default": false,
                    "sm": 12
                },
                "combinedEnvironment": {
                    "label": "Combined environment",
                    "help": "Outdated",
                    "type": "checkbox",
                    "default": false,
                    "sm": 12,
                    "md": 6,
                    "lg": 3,
                    "disabled": "!data.simulationEnabled"
                },
                "simulateAddress": {
                    "label": "Source address",
                    "type": "number",
                    "min": 1,
                    "max": 252,
                    "default": 204,
                    "sm": 12,
                    "md": 6,
                    "lg": 3,
                    "disabled": "!data.simulationEnabled"
                },
                "simulate": {
                    "label": "Simulate",
                    "type": "table",
                    "hidden": "!data.simulationEnabled",
                    "items": [
                        {
                            "attr": "type",
                            "type": "select",
                            "options": [
                                {
                                    "label": "Temperature",
                                    "value": "temperature"
                                },
                                {
                                    "label": "Humidity",
                                    "value": "humidity"
                                },
                                {
                                    "label": "Pressure",
                                    "value": "pressure"
                                },
                                {
                                    "label": "Tank",
                                    "value": "tank"
                                }
                            ]
                        },
                        {
                            "attr": "subType",
                            "type": "select",
                            "options": [
                                {
                                    "label": "Sea Temperature",
                                    "value": "Sea Temperature",
                                    "hidden": "data.type !== 'temperature'"
                                },
                                {
                                    "label": "Outside Temperature",
                                    "value": "Outside Temperature",
                                    "hidden": "data.type !== 'temperature'"
                                },
                                {
                                    "label": "Inside Temperature",
                                    "value": "Inside Temperature",
                                    "hidden": "data.type !== 'temperature'"
                                },
                                {
                                    "label": "Engine Room Temperature",
                                    "value": "Engine Room Temperature",
                                    "hidden": "data.type !== 'temperature'"
                                },
                                {
                                    "label": "Main Cabin Temperature",
                                    "value": "Main Cabin Temperature",
                                    "hidden": "data.type !== 'temperature'"
                                },
                                {
                                    "label": "Live Well Temperature",
                                    "value": "Live Well Temperature",
                                    "hidden": "data.type !== 'temperature'"
                                },
                                {
