                            "defaultFunc": "data.type === 'tank' ? 'Fuel' : (data.type === 'pressure' ? 'Atmospheric' : (data.type === 'humidity' ? 'Outside' : 'Outside Temperature'))"
                        },
                        {
                            "attr": "oid",
                            "type": "objectId",
                            "label": "Object ID"
                        },
                        {
                            "attr": "instance",
                            "type": "number",
                            "label": "Tank instance",
                            "min": 0,
                            "max": 13,
                            "default": 0,
                            "hidden": "data.type !== 'tank'"
                        },
                        {
                            "attr": "capacity",
                            "type": "number",
                            "label": "Capacity (L)",
                            "min": 0,
                            "default": 0,
