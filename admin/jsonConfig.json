                                    "hidden": "data.type !== 'pressure'"
                                },
                                {
                                    "value": "Fuel",
                                    "label": "Tank: Fuel",
                                    "hidden": "data.type !== 'tank'"
                                },
                                {
                                    "value": "Water",
                                    "label": "Tank: Water",
                                    "hidden": "data.type !== 'tank'"
                                },
                                {
                                    "value": "Gray water",
                                    "label": "Tank: Gray water",
                                    "hidden": "data.type !== 'tank'"
                                },
                                {
                                    "value": "Live well",
                                    "label": "Tank: Live well",
                                    "hidden": "data.type !== 'tank'"
                                },
                                {
                                    "value": "Oil",
                                    "label": "Tank: Oil",
                                    "hidden": "data.type !== 'tank'"
